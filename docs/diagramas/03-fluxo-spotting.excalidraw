    { "type": "text", "id": "title", "x": 40, "y": 20, "width": 980, "height": 35, "text": "A vida de um Spotting — modelo Waze com Supressão", "originalText": "A vida de um Spotting — modelo Waze com Supressão", "fontSize": 28, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600001, "version": 1, "versionNonce": 600002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "subtitle", "x": 40, "y": 62, "width": 1200, "height": 20, "text": "ADR 0007: a entidade é compartilhada e a deduplicação é humana · ciclo: ativo → suprimido (reversível) → expirado", "originalText": "ADR 0007: a entidade é compartilhada e a deduplicação é humana · ciclo: ativo → suprimido (reversível) → expirado", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600003, "version": 1, "versionNonce": 600004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

