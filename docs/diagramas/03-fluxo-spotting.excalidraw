    { "type": "text", "id": "e3", "x": 560, "y": 130, "width": 420, "height": 14, "text": "cria Zona de Interesse → frequência de posições sobe (ADR 0001)", "originalText": "cria Zona de Interesse → frequência de posições sobe (ADR 0001)", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#3b82f6", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600009, "version": 1, "versionNonce": 600010, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

