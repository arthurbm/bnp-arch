    { "type": "text", "id": "c1", "x": 395, "y": 142, "width": 340, "height": 18, "text": "1. Disponibilidade do caminho crítico", "originalText": "1. Disponibilidade do caminho crítico", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 800023, "version": 1, "versionNonce": 800024, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
