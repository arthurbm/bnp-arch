    { "type": "text", "id": "l1a", "x": 800, "y": 120, "width": 660, "height": 14, "text": "(A,M) pânico durante pico com broker de massa degradado → socorro segue funcionando", "originalText": "(A,M) pânico durante pico com broker de massa degradado → socorro segue funcionando", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 800049, "version": 1, "versionNonce": 800050, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "l1b", "x": 800, "y": 162, "width": 660, "height": 14, "text": "(A,B) ack do pânico ≤ 5s sob pico — caminho dedicado, ocioso por definição", "originalText": "(A,B) ack do pânico ≤ 5s sob pico — caminho dedicado, ocioso por definição", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 800051, "version": 1, "versionNonce": 800052, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "l1c", "x": 800, "y": 204, "width": 660, "height": 14, "text": "(A,A) queda do próprio serviço de Emergência → redundância + fallback SMS externo", "originalText": "(A,A) queda do próprio serviço de Emergência → redundância + fallback SMS externo", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 800053, "version": 1, "versionNonce": 800054, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

