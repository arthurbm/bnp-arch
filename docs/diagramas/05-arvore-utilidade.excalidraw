    { "type": "text", "id": "l2a", "x": 800, "y": 300, "width": 660, "height": 14, "text": "(A,M) carro 40 min offline: app segue funcional; buffer sobe com a hora da medição", "originalText": "(A,M) carro 40 min offline: app segue funcional; buffer sobe com a hora da medição", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 800061, "version": 1, "versionNonce": 800062, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "l2b", "x": 800, "y": 342, "width": 660, "height": 14, "text": "(A,M) guia com rede oscilando: QoS 1 reentrega + SMS + \"não respondeu\" visível", "originalText": "(A,M) guia com rede oscilando: QoS 1 reentrega + SMS + \"não respondeu\" visível", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 800063, "version": 1, "versionNonce": 800064, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
